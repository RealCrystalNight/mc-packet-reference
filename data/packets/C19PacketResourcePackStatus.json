{
  "id": "C19PacketResourcePackStatus",
  "hex": "0x19",
  "dec": 25,
  "dir": "SERVERBOUND",
  "state": "PLAY",
  "name": "Resource Pack Status",
  "desc": "Client reports the resource pack load status to the server. Sent after S48PacketResourcePackSend.",
  "tags": [
    "resourcepack",
    "download"
  ],
  "fields": [
    {
      "name": "hash",
      "type": "String",
      "desc": "SHA-1 hash of the resource pack (from S48)"
    },
    {
      "name": "status",
      "type": "VarInt Enum",
      "desc": "0=loaded, 1=declined, 2=failedDownload, 3=accepted"
    }
  ],
  "encoding": [
    [
      "Hash",
      "String",
      "SHA-1 hash of the pack"
    ],
    [
      "Result",
      "VarInt Enum",
      "0=loaded, 1=declined, 2=failedDownload, 3=accepted"
    ]
  ],
  "mcp": [
    "NetHandlerPlayServer.processResourcePackStatus()"
  ],
  "handler": "INetHandlerPlayServer",
  "notes": "The server can force a resource pack. If the client declines, the server may kick the player.",
  "implementation": {
    "modules": [
      {
        "name": "AntiResourcePack",
        "found_in": [],
        "purpose": "Cancel resource pack downloads or fake acceptance.",
        "how_it_works": "",
        "detailed_code": "if (event.getPacket() instanceof C19PacketResourcePackStatus) event.setCancelled(true);",
        "vanilla_hook": "EventSendPacket"
      }
    ]
  }
}